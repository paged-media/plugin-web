{
  "name": "@paged-media/web",
  "private": false,
  "version": "0.1.0-canary.1",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./manifest.json": "./manifest.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "build": "tsup",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@paged-media/plugin-api": "0.2.25-canary.0",
    "@paged-media/plugin-sdk": "0.2.25-canary.0"
  },
  "peerDependencies": {
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "20.19.39",
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "@paged-media/web-model": "workspace:*"
  },
  "files": [
    "bin",
    "dist",
    "manifest.json"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "canary",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./manifest.json": "./manifest.json"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paged-media/plugin-web.git",
    "directory": "packages/web-bundle"
  }
}
