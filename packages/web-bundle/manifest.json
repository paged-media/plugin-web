{
  "id": "media.paged.web",
  "name": "paged.web",
  "version": "0.1.2",
  "apiVersion": "^0.2",
  "publisher": "paged.media",
  "capabilities": {
    "document": {
      "read": "broad",
      "write": "scoped"
    },
    "rendering": [
      "hitTest"
    ],
    "editContext": [
      "webFrame"
    ],
    "assets": [
      "fonts"
    ],
    "network": false,
    "clipboard": "none"
  },
  "contributes": {
    "panels": [
      "media.paged.web.panel.source"
    ],
    "commands": [
      "media.paged.web.command.insertWebFrame"
    ],
    "editContexts": [
      {
        "type": "webFrame",
        "entry": "doubleClick"
      }
    ],
    "objectTypes": [
      {
        "type": "webFrame",
        "bakedFallback": "rectangle"
      }
    ]
  }
}