{
  "id": "media.paged.web",
  "name": "paged.web",
  "version": "0.1.0",
  "apiVersion": "^0.2",
  "publisher": "paged.media",
  "capabilities": {
    "document": { "read": "broad", "write": "scoped" },
    "rendering": ["hitTest"],
    "editContext": ["webFrame"],
    "network": false,
    "clipboard": "none"
  },
  "contributes": {
    "panels": ["media.paged.web.panel.source"],
    "commands": [
      "media.paged.web.command.insertWebFrame",
      "media.paged.web.panel.source.show",
      "media.paged.web.panel.source.hide"
    ],
    "editContexts": [{ "type": "webFrame", "entry": "doubleClick" }],
    "objectTypes": [{ "type": "webFrame", "bakedFallback": "rectangle" }]
  }
}
